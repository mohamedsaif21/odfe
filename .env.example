# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Razorpay (Day 24) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ─── Storage ─────────────────────────────────────────────────────────────────
# Supabase Storage is used — no S3 keys needed.
# Bucket names (configure in Supabase dashboard):
# - product-images
# - receipt-pdfs
# - qr-codes

# ─── Email (optional — for receipt emails, Day 14) ───────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Dev ────────────────────────────────────────────────────────────────────
# Set to "true" to skip auth middleware locally
NEXT_PUBLIC_DEV_SKIP_AUTH=
